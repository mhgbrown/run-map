{
  "name": "run-map",
  "version": "1.0.0",
  "description": "An interactive map showcasing runs tracked various trackers.",
  "main": "index.html",
  "scripts": {
    "start": "http-server . -p 3030 -c-1",
    "parse": "node src/parser/parse.js",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\" \"!data/**\"",
    "test": "node --test"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.6.0",
